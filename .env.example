# ============================================================
#  KidTrack — Variables d'environnement
#  Copiez ce fichier en ".env" et remplissez les valeurs
#  Railway injecte ces variables automatiquement
# ============================================================

# Port du serveur (Railway le définit automatiquement)
PORT=3000

# Clé secrète pour sécuriser les sessions (changez cette valeur !)
SECRET_KEY=kidtrack_secret_changez_moi_2024

# Optionnel : Twilio pour les SMS réels
# TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM=+12345678901
